{
  "cleanUrls": true,
  "rewrites": [
    {
       "source": "/api/(.*)",
       "destination": "https://shieldtrace-api-production.up.railway.app/api/$1"
    },
    {
      "source": "/",
      "destination": "/outputs/index.html"
    },
    {
      "source": "/styles.css",
      "destination": "/outputs/styles.css"
    },
    {
      "source": "/app.js",
      "destination": "/outputs/app.js"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}
